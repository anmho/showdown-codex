{
  "manifest_version": 3,
  "name": "Showdown Codex Autopilot",
  "version": "0.1.0",
  "description": "Plays Pokemon Showdown autonomously using codex app-server inference (gpt-5.4-codex, low/medium effort).",
  "permissions": ["storage"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Showdown Codex Autopilot"
  },
  "content_scripts": [
    {
      "matches": ["https://play.pokemonshowdown.com/*"],
      "js": ["content-main.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": ["https://play.pokemonshowdown.com/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
